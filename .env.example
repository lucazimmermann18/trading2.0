# ──────────────────────────────────────────────────────────────────────────────
# TradeAI Pro — Environment Variables
# Copy this file to .env.local for local development.
# In production (Vercel), add these in:
#   Project Settings → Environment Variables
# ──────────────────────────────────────────────────────────────────────────────

# Twelve Data API key — used server-side to fetch historical OHLC bars.
# Get your key at: https://twelvedata.com/account/api-keys
# Required for bar loading to work in production.
TWELVE_DATA_API_KEY=your_key_here

# Twelve Data API key — used client-side for WebSocket live price feed.
# Must be the same key (or a separate one with WS plan).
# Required for live price ticks in the chart.
NEXT_PUBLIC_TWELVE_DATA_API_KEY=your_key_here

# ──────────────────────────────────────────────────────────────────────────────
# AI provider API keys are entered by the user at runtime in the Settings modal.
# They are stored in localStorage and never sent to the server.
# You do NOT need to add them here.
# ──────────────────────────────────────────────────────────────────────────────
